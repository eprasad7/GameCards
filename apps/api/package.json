  },
  "dependencies": {
    "agents": "^0.11.0",
    "ai": "^6.0.161",
    "hono": "^4.7.0",
    "workers-ai-provider": "^3.1.10"
  },
  "devDependencies": {
    "@cloudflare/puppeteer": "^1.1.0",
    "@cloudflare/workers-types": "^4.20250410.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.4",
    "wrangler": "^4.10.0"
  }
}
